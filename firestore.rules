rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read assets and curriculum map. Only admins can write them.
    match /assets/{assetId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /curriculum_map/{mapId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Users can read/write their own learning paths.
    match /users/{userId}/learning_paths/{pathId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Server-only collection for snapshot check-pointing and database history.
    match /cms_history/{commitId} {
      allow read, write: if false;
    }

    // Telemetry invalidation log (read-only for clients to sync cache, write blocked).
    match /cache_invalidations/{invalidationId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
